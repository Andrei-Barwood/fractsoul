FROM golang:1.24-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/reporter ./cmd/reporter

FROM alpine:3.20

RUN apk add --no-cache tzdata
RUN adduser -D -u 10001 appuser
USER appuser

COPY --from=builder /out/reporter /usr/local/bin/reporter

ENTRYPOINT ["/usr/local/bin/reporter"]
