# Core app
APP_PORT=8080
GIN_MODE=release
LOG_LEVEL=info

# Auth + RBAC
API_AUTH_ENABLED=true
API_RBAC_ENABLED=true
API_KEY_HEADER=X-API-Key
API_KEYS=viewer-key,operator-key,admin-key
API_DEFAULT_ROLE=viewer
API_KEY_ROLES=viewer-key:viewer,operator-key:operator,admin-key:admin

# Messaging + DB
NATS_URL=nats://localhost:4222
TELEMETRY_SUBJECT=telemetry.raw.v1
TELEMETRY_STREAM=TELEMETRY
TELEMETRY_DLQ_SUBJECT=telemetry.dlq.v1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mining?sslmode=disable

# Secrets via files (preferred for production)
# DATABASE_URL_FILE=/run/secrets/database_url
# API_KEYS_FILE=/run/secrets/api_keys
# API_KEY_ROLES_FILE=/run/secrets/api_key_roles
# ALERT_WEBHOOK_TOKEN_FILE=/run/secrets/alert_webhook_token
# ALERT_SMTP_PASSWORD_FILE=/run/secrets/alert_smtp_password
